<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder dependency-injector="ds" package-path="com.liferay.test.factory">
	<namespace>TestFactory</namespace>
	<entity local-service="true" name="CalcEntry" remote-service="true">

		<!-- PK fields -->

		<column name="calcEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Calculator fields -->

		<column name="num1" type="double" />
		<column name="num2" type="double" />
		<column name="operator" type="String" />
		<column name="result" type="double" />

		<!-- Order -->

		<order by="desc">
			<order-column name="createDate" />
		</order>

		<!-- Finder methods -->

		<finder name="UserId" return-type="Collection">
			<finder-column name="userId" />
		</finder>
	</entity>
</service-builder>
